# Performance Testing Configuration
# Copy this file to .env and customize as needed

# API Configuration
# Default: http://localhost:8080/api
API_URL=http://localhost:8080/api

# Test Data Configuration
# Number of contacts to expect in database
# Default: 10000
CONTACT_COUNT=10000

# Soak Test Duration (in minutes)
# How long to sustain load during soak test
# Default: 60 (1 hour)
TEST_DURATION_SOAK=60

# Logging Level
# Options: debug, info, warn, error
# Default: info
LOG_LEVEL=info

# Optional: Artifact Storage Path
# Where to archive test results for historical comparison
# Example: /mnt/performance-storage or s3://bucket-name
# Default: ./results (local)
ARTIFACT_STORAGE=./results

# Optional: InfluxDB Configuration (for Phase 4 - Visualization)
# INFLUXDB_USER=admin
# INFLUXDB_PASSWORD=password
# INFLUXDB_TOKEN=your-token-here

# Optional: Grafana Configuration (for Phase 4 - Visualization)
# GRAFANA_USER=admin
# GRAFANA_PASSWORD=admin
